Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On

# Canonical host: HTTPS + non-www
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.cekamezbaha\.com$ [NC]
RewriteRule ^ https://cekamezbaha.com%{REQUEST_URI} [R=301,L,NE]

# Remove explicit index/index.html from root and language folders
RewriteRule ^(en|ru|ar|ben)/index\.html$ /$1/ [R=301,L,NC,NE]
RewriteRule ^index\.html$ / [R=301,L,NC,NE]
RewriteRule ^(en|ru|ar|ben)/index$ /$1/ [R=301,L,NC,NE]
RewriteRule ^index$ / [R=301,L,NC,NE]

# Remove .html from public URLs
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[\s?]|$) [NC]
RewriteRule ^ %1 [R=301,L,NE]

# Remove trailing slash from non-directory URLs, but keep language roots
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_URI} !^/(en|ru|ar|ben)/$
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L,NE]

# Serve extensionless URLs from matching .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !\.[A-Za-z0-9]{1,8}$
RewriteRule ^(.+)$ $1.html [L,NC]
</IfModule>

<IfModule mod_mime.c>
AddCharset UTF-8 .html .css .js .xml .txt
</IfModule>

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set X-Robots-Tag "all"

<FilesMatch "\.(html|htm)$">
Header always set Cache-Control "public, max-age=600, must-revalidate"
</FilesMatch>

<FilesMatch "\.(css|js|mjs|jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf|otf|mp4)$">
Header always set Cache-Control "public, max-age=2592000, immutable"
</FilesMatch>
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/html "access plus 10 minutes"
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
ExpiresByType text/javascript "access plus 1 month"
ExpiresByType image/jpeg "access plus 1 month"
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/gif "access plus 1 month"
ExpiresByType image/webp "access plus 1 month"
ExpiresByType image/svg+xml "access plus 1 month"
ExpiresByType image/x-icon "access plus 1 month"
ExpiresByType font/woff2 "access plus 1 month"
ExpiresByType video/mp4 "access plus 1 month"
ExpiresByType application/xml "access plus 1 day"
ExpiresByType text/plain "access plus 1 day"
</IfModule>

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>
